{
	"compilerOptions": {
		"module": "commonjs",
		"target": "es2020",
		"noImplicitAny": false,
		"removeComments": false,
		"noUnusedLocals": true,
		"noImplicitThis": true,
		"inlineSourceMap": false,
		"sourceMap": true,
    "rootDir": "./src",
		"outDir": "out",
		"preserveConstEnums": true,
		"strictNullChecks": true,
		"noUnusedParameters": false
	},
  "exclude": ["node_modules", ".vscode-test"]
}
